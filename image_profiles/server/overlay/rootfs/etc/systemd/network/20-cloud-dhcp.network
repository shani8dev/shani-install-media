# Matches all Ethernet interfaces — covers ens5, eth0, enp*s* on AWS Nitro.
# Name=!lo excludes the loopback interface.
[Match]
Type = ether
Name = !lo

[Network]
DHCP = yes
IPv6AcceptRA = yes
MulticastDNS = no
LLDP = no
EmitLLDP = no

[DHCP]
UseDNS = yes
UseNTP = yes
UseMTU = yes
RouteMetric = 100
