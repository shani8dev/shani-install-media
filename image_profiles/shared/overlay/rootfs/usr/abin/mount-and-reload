#!/bin/bash

# Mount all overlay filesystems FIRST.
# Log any failures — nofail entries in fstab mean boot continues, but missing
# bind-mount source dirs (/data/varlib/*) will cause services to start without
# their persistent state. Logging makes these failures diagnosable.
if ! mount -a 2>/tmp/shanios-mount-a.err; then
    logger -t mount-and-reload -p syslog.warning \
        "mount -a reported errors: $(cat /tmp/shanios-mount-a.err 2>/dev/null | tr '\n' ' ')"
fi
rm -f /tmp/shanios-mount-a.err

# THEN reload systemd to discover services in the overlay.
# --no-block prevents deadlock: this script runs as a systemd service,
# a blocking daemon-reload would wait for itself to finish.
systemctl daemon-reload --no-block
