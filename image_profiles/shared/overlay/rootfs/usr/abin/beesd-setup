#!/bin/bash
set -uo pipefail

ROOTLABEL="shani_root"
SCRIPT_VERSION="1"

log() { echo "$(date "+%Y-%m-%d %H:%M:%S") [beesd-setup] $*"; }

if [[ ! -e "/dev/disk/by-label/${ROOTLABEL}" ]] && [[ ! -e "/dev/mapper/${ROOTLABEL}" ]]; then
    log "ERROR: Device not found — both by-label and mapper missing."
    exit 0
fi

UUID=$(blkid -s UUID -o value /dev/disk/by-label/"${ROOTLABEL}" 2>/dev/null || true)
if [[ -z "$UUID" ]] && [[ -e "/dev/mapper/${ROOTLABEL}" ]]; then
    UUID=$(blkid -s UUID -o value /dev/mapper/"${ROOTLABEL}" 2>/dev/null || true)
fi

if [[ -z "$UUID" ]]; then
    log "ERROR: Could not resolve BTRFS UUID for ${ROOTLABEL}."
    exit 0
fi

CONF="/etc/bees/${UUID}.conf"
SERVICE="beesd@${UUID}.service"

if [[ -f "$CONF" ]] \
    && grep -q "^# version=${SCRIPT_VERSION}$" "$CONF" 2>/dev/null \
    && systemctl is-enabled --quiet "$SERVICE" 2>/dev/null; then
    log "Already configured (version=${SCRIPT_VERSION}), skipping."
    exit 0
fi

if [[ -e "/dev/disk/by-uuid/${UUID}" ]]; then
    BTRFS_DEV="/dev/disk/by-uuid/${UUID}"
elif [[ -e "/dev/mapper/${ROOTLABEL}" ]]; then
    BTRFS_DEV="/dev/mapper/${ROOTLABEL}"
else
    BTRFS_DEV="/dev/disk/by-label/${ROOTLABEL}"
fi

log "Writing ${CONF} (UUID=${UUID}, device=${BTRFS_DEV})"
mkdir -p /etc/bees || { log "ERROR: cannot create /etc/bees"; exit 0; }

cat > "$CONF" <<CONF
# /etc/bees/${UUID}.conf
# Generated by beesd-setup.sh — do not edit manually.
# version=${SCRIPT_VERSION}
UUID=${UUID}

_fs_bytes=\$(lsblk -b -no SIZE "${BTRFS_DEV}" 2>/dev/null | head -1 | tr -d '[:space:]')
_fs_bytes=\$(( \${_fs_bytes:-0} ))
_fs_tb=\$(( (_fs_bytes + 500000000000) / 1000000000000 ))
_fs_tb=\$(( _fs_tb < 1 ? 1 : _fs_tb ))
_fs_tb=\$(( _fs_tb > 4 ? 4 : _fs_tb ))
DB_SIZE=\$(( _fs_tb * 256 * 1024 * 1024 ))

OPTIONS="--strip-paths --no-timestamps --throttle-factor 1.0"
CONF

if ! systemctl is-enabled --quiet "$SERVICE" 2>/dev/null; then
    log "Enabling ${SERVICE}"
    systemctl enable "$SERVICE" 2>/dev/null || log "WARN: could not enable ${SERVICE}"
fi

log "Done — UUID=${UUID}"
