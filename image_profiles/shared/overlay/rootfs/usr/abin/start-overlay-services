#!/bin/bash
OVERLAY_UPPER="/data/overlay/etc/upper/systemd/system"
services_started=0
services_list=""

start_if_needed() {
    local service="$1"
    systemctl is-active --quiet "$service" 2>/dev/null && return
    local result
    result=$(systemctl show --property=Result --value "$service" 2>/dev/null)
    [[ "$result" == "exit-code" || "$result" == "signal" || "$result" == "timeout" || "$result" == "watchdog" || "$result" == "oom-kill" ]] && return
    local ts
    ts=$(systemctl show --property=InactiveEnterTimestamp --value "$service" 2>/dev/null)
    [[ -n "$ts" ]] && return
    systemctl start "$service" 2>/dev/null &
    ((services_started++))
    services_list="$services_list $service"
}

# Pass 1: enabled unit files that exist in overlay upper
while read -r service; do
    [[ "$service" == *"@.service" ]] && continue
    find "$OVERLAY_UPPER" -name "$service" 2>/dev/null | grep -q . || continue
    start_if_needed "$service"
done < <(systemctl list-unit-files --type=service --state=enabled --no-legend | awk '{print $1}')

# Pass 2: template instances whose symlink is in overlay upper .wants dirs
while read -r symlink; do
    service=$(basename "$symlink")
    [[ "$service" == *"@.service" ]] && continue
    [[ "$service" != *"@"* ]] && continue
    start_if_needed "$service"
done < <(find "$OVERLAY_UPPER"/*.wants -name "*.service" 2>/dev/null)

[ $services_started -gt 0 ] && echo "Started $services_started new overlay services:$services_list" || echo "No new overlay services to start"
touch /run/start-overlay-services.done
