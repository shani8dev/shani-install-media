#!/bin/bash
# start-overlay-services — immutable Blue/Green btrfs root
# Starts overlay-enabled units in parallel; logs what was fired.
#
# snap mount unit naming on this system:
#   var-lib-snapd-snap-*.mount  — canonical form, active/mounted (fire these)
#   snap-*.mount                — alias form, fail if canonical already mounted (skip these)
# /var/snap is a runtime bind mount created by snapd, not a directory on disk.

set -euo pipefail

OVERLAY_UPPER="${OVERLAY_UPPER:-/data/overlay/etc/upper/systemd/system}"
DONE_FILE="${DONE_FILE:-/run/start-overlay-services.done}"

UNIT_EXTS="*.service *.mount *.socket *.timer *.path *.target *.slice *.scope *.swap *.automount"

is_startable() {
    local unit="$1"
    local active_state
    active_state=$(systemctl show --property=ActiveState --value "$unit" 2>/dev/null || true)
    case "$active_state" in
        active|activating|reloading) return 1 ;;
    esac
    local result
    result=$(systemctl show --property=Result --value "$unit" 2>/dev/null || true)
    case "$result" in
        exit-code|signal|timeout|watchdog|oom-kill) return 1 ;;
    esac
    return 0
}

collect_units() {
    local upper="$1"
    local -n _out=$2

    [[ -d "$upper" ]] || return 0

    local ext_args=()
    local first=1
    for ext in $UNIT_EXTS; do
        [[ $first -eq 1 ]] && first=0 || ext_args+=(-o)
        ext_args+=(-name "$ext")
    done

    while IFS= read -r -d '' f; do
        _out["$(basename "$f")"]=1
    done < <(find "$upper" -maxdepth 1 -type f \( "${ext_args[@]}" \) -print0 2>/dev/null)

    while IFS= read -r -d '' s; do
        _out["$(basename "$s")"]=1
    done < <(find "$upper" -maxdepth 2 \
                  \( -name "*.wants" -o -name "*.requires" \) -type d -print0 2>/dev/null \
             | xargs -0 -r find -maxdepth 1 \( "${ext_args[@]}" \) -print0 2>/dev/null)
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
declare -A seen
declare -a pids=()
declare -a started_units=()

collect_units "$OVERLAY_UPPER" seen

# Pass 1: overlay-managed units of all types.
# Skip snap-*.mount aliases — they fail if the canonical var-lib-snapd-snap-*
# form is already mounted at the same path.
for unit in "${!seen[@]}"; do
    [[ "$unit" == snap-*.mount ]] && continue
    is_startable "$unit" || continue
    systemctl start "$unit" 2>/dev/null &
    pids+=($!)
    started_units+=("$unit")
done

# Pass 2: snap squashfs loopbacks — canonical var-lib-snapd-snap-*.mount form only.
# These are active when snapd has already set up state.json but the loopbacks
# were torn down by the btrfs subvolume switch.
# Skip anything already fired in Pass 1.
while IFS= read -r unit; do
    [[ -v seen["$unit"] ]] && continue
    what=$(systemctl show --property=What --value "$unit" 2>/dev/null || true)
    [[ "$what" == *.snap ]] || continue
    is_startable "$unit" || continue
    systemctl start "$unit" 2>/dev/null &
    pids+=($!)
    started_units+=("$unit")
done < <(systemctl list-units --type=mount --all --no-legend --plain 2>/dev/null \
         | awk '/^var-lib-snapd-snap-/ { print $1 }')

failed=0
for pid in "${pids[@]}"; do
    wait "$pid" || failed=$((failed + 1))
done

total=${#started_units[@]}
if [[ $total -gt 0 ]]; then
    printf 'start-overlay-services: fired %d unit(s) (%d failed):\n' "$total" "$failed"
    printf '  %s\n' "${started_units[@]}"
else
    echo "start-overlay-services: nothing fired"
fi

touch "$DONE_FILE"
