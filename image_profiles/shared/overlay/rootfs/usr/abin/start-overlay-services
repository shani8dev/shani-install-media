#!/bin/bash

STAMP="/run/start-overlay-services.done"
if [[ -f "$STAMP" ]]; then
    echo "Overlay services already started this session, skipping."
    exit 0
fi

services_started=0
services_list=""

while read -r service; do
    [[ "$service" == *"@"* ]] && continue

    # One dbus call per service — parse by key=value, NOT by line order
    # (systemd does not guarantee property output order)
    props=$(systemctl show \
        --property=ActiveState \
        --property=InactiveExitTimestamp \
        --property=ExecMainExitTimestamp \
        "$service" 2>/dev/null)

    active_state=$(echo "$props"   | grep '^ActiveState='           | cut -d= -f2)
    inactive_exit=$(echo "$props"  | grep '^InactiveExitTimestamp=' | cut -d= -f2-)
    exec_main_exit=$(echo "$props" | grep '^ExecMainExitTimestamp=' | cut -d= -f2-)

    # Already active — skip
    [[ "$active_state" == "active" ]] && continue

    # Has run before (has exit timestamps) — skip
    [[ -n "$inactive_exit" || -n "$exec_main_exit" ]] && continue

    systemctl start "$service" &
    ((services_started++))
    services_list="$services_list $service"
done < <(systemctl list-unit-files --type=service --state=enabled --no-legend | awk '{print $1}')

wait

if [ $services_started -gt 0 ]; then
    echo "Started $services_started new overlay services:$services_list"
else
    echo "No new overlay services to start"
fi

touch "$STAMP"
