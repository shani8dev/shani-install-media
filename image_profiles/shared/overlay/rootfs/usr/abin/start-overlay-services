#!/bin/bash
services_started=0
services_list=""

while read -r service; do
    [[ "$service" == *"@"* ]] && continue

    if ! systemctl is-active --quiet "$service"; then
        if systemctl is-enabled --quiet "$service" 2>/dev/null; then
            start_time=$(systemctl show --property=ActiveEnterTimestamp --value "$service" 2>/dev/null)
            [[ -z "$start_time" ]] && \
                start_time=$(systemctl show --property=ExecMainStartTimestamp --value "$service" 2>/dev/null)
            [[ -z "$start_time" ]] && \
                start_time=$(systemctl show --property=InactiveEnterTimestamp --value "$service" 2>/dev/null)

            if [[ -z "$start_time" ]]; then
                systemctl start "$service" &
                ((services_started++))
                services_list="$services_list $service"
            fi
        fi
    fi
done < <(systemctl list-unit-files --type=service --state=enabled --no-legend | awk '{print $1}')
wait

if [ $services_started -gt 0 ]; then
    echo "Started $services_started new overlay services:$services_list"
else
    echo "No new overlay services to start"
fi

touch /run/start-overlay-services.done
