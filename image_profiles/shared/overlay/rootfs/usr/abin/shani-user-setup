#!/bin/bash

EXTRA_GROUPS="input,realtime,video,sys,cups,lp,scanner,nixbld,lxc,lxd,kvm,libvirt"

# Process every regular user (UID 1000–59999).
while IFS=: read -r username _ uid _; do

    # Build list of groups from EXTRA_GROUPS that this user is missing.
    missing=()
    IFS=',' read -ra wanted <<< "$EXTRA_GROUPS"
    for group in "${wanted[@]}"; do
        # Skip groups that don't exist on the system yet
        getent group "$group" &>/dev/null || continue
        # Check if user is already a member
        id -nG "$username" 2>/dev/null | tr ' ' '\n' | grep -qx "$group" || missing+=("$group")
    done

    if [[ ${#missing[@]} -eq 0 ]]; then
        echo "shani-user-setup: $username already has all groups, skipping."
        continue
    fi

    echo "shani-user-setup: adding $username to: ${missing[*]}"
    usermod -aG "$(IFS=','; echo "${missing[*]}")" "$username"

    # Set default shell to zsh if available and not already set
    if [[ -x /bin/zsh ]]; then
        current_shell=$(getent passwd "$username" | cut -d: -f7)
        if [[ "$current_shell" != "/bin/zsh" ]]; then
            usermod -s /bin/zsh "$username"
        fi
    fi

done < <(awk -F: '$3 >= 1000 && $3 < 60000 {print $1, $2, $3, $4}' OFS=: /etc/passwd)
