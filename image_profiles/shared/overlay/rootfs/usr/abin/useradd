#!/bin/bash
# ShaniOS useradd wrapper — merges ShaniOS extra groups into every useradd call.
# Reads extra groups from /etc/shani-extra-groups (shared with adduser wrapper
# and shani-user-setup). Falls back to built-in default if file is missing.
#
# Install: /usr/local/bin/useradd  (shadows /usr/bin/useradd via PATH)

EXTRA_GROUPS_FILE="/etc/shani-extra-groups"

DEFAULT_EXTRA_GROUPS=""
if [[ -f "$EXTRA_GROUPS_FILE" ]]; then
    DEFAULT_EXTRA_GROUPS=$(head -n1 "$EXTRA_GROUPS_FILE" 2>/dev/null | tr -d '[:space:]')
fi

# Check that the underlying binary exists before doing anything
REAL_BIN="/usr/bin/useradd"
if [[ ! -x "$REAL_BIN" ]]; then
    echo "shani useradd wrapper: $REAL_BIN not found or not executable" >&2
    exit 127
fi

# Keep only groups that exist on this system
EXISTING_GROUPS=""
IFS=',' read -ra groups <<< "$DEFAULT_EXTRA_GROUPS"
for g in "${groups[@]}"; do
    if getent group "$g" >/dev/null; then
        EXISTING_GROUPS+="${EXISTING_GROUPS:+,}$g"
    fi
done

new_args=()
provided_G=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -G)
            provided_G=1
            shift
            provided_groups="$1"
            if [[ -n "$EXISTING_GROUPS" ]]; then
                merged=$(echo "${provided_groups:+${provided_groups},}${EXISTING_GROUPS}" \
                    | tr ',' '\n' | sort -u | tr '\n' ',' | sed 's/,$//')
            else
                merged="$provided_groups"
            fi
            new_args+=("-G" "$merged")
            shift
            ;;
        -G*)
            provided_G=1
            provided_groups="${1:2}"
            if [[ -n "$EXISTING_GROUPS" ]]; then
                merged=$(echo "${provided_groups:+${provided_groups},}${EXISTING_GROUPS}" \
                    | tr ',' '\n' | sort -u | tr '\n' ',' | sed 's/,$//')
            else
                merged="$provided_groups"
            fi
            new_args+=("-G" "$merged")
            shift
            ;;
        *)
            new_args+=("$1")
            shift
            ;;
    esac
done

if [[ $provided_G -eq 0 ]]; then
    if [[ -z "$EXISTING_GROUPS" ]]; then
        echo "shani useradd wrapper: WARNING: no groups from '$EXTRA_GROUPS_FILE' exist on this system — skipping -G" >&2
    else
        new_args+=("-G" "$EXISTING_GROUPS")
    fi
fi

exec "$REAL_BIN" "${new_args[@]}"
