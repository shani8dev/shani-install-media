[Unit]
Description=Bees BTRFS deduplication setup
Documentation=https://github.com/Zygo/bees
After=local-fs.target dev-disk-by\x2dlabel-shani_root.device etc-overlay.mount
Requires=local-fs.target
Wants=dev-disk-by\x2dlabel-shani_root.device etc-overlay.mount
Before=etc-daemon-reload.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/abin/beesd-setup
Restart=on-failure
RestartSec=5s
StartLimitIntervalSec=60s
StartLimitBurst=3

[Install]
WantedBy=multi-user.target
