# ============================================================================
# /etc/fstab - ShaniOS Immutable OS Configuration
# ============================================================================
# System: ShaniOS - UEFI with Btrfs Blue/Green Root Snapshots
# Bootloader: systemd-boot
# Design: Immutable blue/green root with selective persistence
# Kernel Parameter: systemd.volatile=state
# Root Subvolumes: @blue OR @green (selected at boot)
# ============================================================================

##############################################################################
# ARCHITECTURE OVERVIEW
##############################################################################
#
# BLUE/GREEN IMMUTABLE ROOT STRATEGY:
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ systemd-boot → Kernel with root= → dracut mounts @blue or @green        │
# │                                                                          │
# │    @blue (inactive)  ←→  @green (active)                                │
# │    Read-only root        Read-only root                                  │
# │                               ↓                                          │
# │                          Mounted as /                                    │
# │                                                                          │
# │ Writable Layers (shared between blue & green):                          │
# │  /etc   → OverlayFS (changes stored in /data/overlay/etc)               │
# │  /var   → tmpfs (volatile, cleared on reboot)                           │
# │  /home  → Persistent Btrfs @home subvolume                              │
# │  /data  → Persistent Btrfs @data subvolume                              │
# │                                                                          │
# │ Update:   Write to inactive root → Switch boot entry → Reboot           │
# │ Rollback: Change systemd-boot entry back → Reboot                       │
# └─────────────────────────────────────────────────────────────────────────┘

##############################################################################
# BTRFS SUBVOLUME MAPPING
##############################################################################
#
# Root Volume: shani_root (main Btrfs filesystem)
#
# Immutable Root Slots (one chosen at boot):
#   @blue        => / (blue root - immutable, read-only)
#   @green       => / (green root - immutable, read-only)
#
# Persistent Data & Storage:
#   @root        => /root        (root user home - persists across root switches)
#   @home        => /home        (user files & configs - survives root switches)
#   @data        => /data        (overlay storage + service state bind sources)
#   @nix         => /nix         (Nix package manager store - shared between roots)
#   @cache       => /var/cache   (package manager cache - shared)
#   @log         => /var/log     (system logs - persistent)
#
# Container & Virtualization:
#   @flatpak     => /var/lib/flatpak    (Flatpak runtimes and apps)
#   @waydroid    => /var/lib/waydroid   (Android system images & userdata)
#   @containers  => /var/lib/containers (Podman/Docker container images)
#   @machines    => /var/lib/machines   (systemd-nspawn containers)
#   @lxc         => /var/lib/lxc        (LXC containers)
#   @lxd         => /var/lib/lxd        (LXD containers)
#   @libvirt     => /var/lib/libvirt    (libvirt VM disks - nodatacow)
#   @qemu        => /var/lib/qemu       (bare QEMU VM disk images - nodatacow)
#
# Swap:
#   @swap        => /swap (swap space - nodatacow)

##############################################################################
# PERSISTENT SERVICE STATE (via bind mounts from @data)
##############################################################################
#
# System Core:
#   /data/varlib/dbus            => /var/lib/dbus
#   /data/varlib/systemd         => /var/lib/systemd
#
# Font Rendering:
#   /data/varlib/fontconfig      => /var/lib/fontconfig
#
# Networking:
#   /data/varlib/NetworkManager  => /var/lib/NetworkManager
#   /data/varlib/bluetooth       => /var/lib/bluetooth
#   /data/varlib/firewalld       => /var/lib/firewalld
#
# File Sharing & Network Services:
#   /data/varlib/samba           => /var/lib/samba
#   /data/varlib/nfs             => /var/lib/nfs
#
# Remote Access & VPN:
#   /data/varlib/caddy           => /var/lib/caddy
#   /data/varlib/tailscale       => /var/lib/tailscale
#   /data/varlib/cloudflared     => /var/lib/cloudflared
#   /data/varlib/geoclue         => /var/lib/geoclue
#
# Display Manager & Desktop:
#   /data/varlib/gdm             => /var/lib/gdm
#   /data/varlib/sddm            => /var/lib/sddm
#   /data/varlib/colord          => /var/lib/colord
#
# Audio & Peripherals:
#   /data/varlib/pipewire        => /var/lib/pipewire
#   /data/varlib/rtkit           => /var/lib/rtkit
#   /data/varlib/cups            => /var/lib/cups
#   /data/varlib/sane            => /var/lib/sane
#   /data/varlib/upower          => /var/lib/upower
#
# Authentication & Security:
#   /data/varlib/fprint          => /var/lib/fprint
#   /data/varlib/AccountsService => /var/lib/AccountsService
#   /data/varlib/boltd           => /var/lib/boltd
#   /data/varlib/sudo            => /var/lib/sudo
#   /data/varlib/sshd            => /var/lib/sshd
#   /data/varlib/polkit-1        => /var/lib/polkit-1
#   /data/varlib/tpm2-tss        => /var/lib/tpm2-tss
#
# Hardware & Firmware:
#   /data/varlib/fwupd           => /var/lib/fwupd
#
# Data Protection & Persistence:
#   /data/varlib/fail2ban        => /var/lib/fail2ban
#   /data/varlib/restic          => /var/lib/restic
#   /data/varlib/rclone          => /var/lib/rclone
#   /data/varlib/appimage        => /var/lib/appimage
#
# Job Scheduling:
#   /data/varspool/anacron       => /var/spool/anacron
#   /data/varspool/cron          => /var/spool/cron
#   /data/varspool/at            => /var/spool/at
#
# Print & Mail Spools:
#   /data/varspool/cups          => /var/spool/cups
#   /data/varspool/samba         => /var/spool/samba
#   /data/varspool/postfix       => /var/spool/postfix

##############################################################################
# MOUNT OPTIONS REFERENCE
##############################################################################
#
# Btrfs Options:
#   noatime         - Disable access time updates (reduces write amplification)
#   compress=zstd   - Enable transparent Zstandard compression
#   space_cache=v2  - Use modern free space cache implementation
#   autodefrag      - Enable automatic background defragmentation
#   nodatacow       - Disable Copy-on-Write (required for VMs and swap)
#   nospace_cache   - Disable space cache (required when using nodatacow)
#   nofail          - Boot continues if subvolume is absent (optional mounts)
#
# systemd Mount Options:
#   x-systemd.after                - Mount after the specified unit starts
#   x-systemd.requires             - Hard dependency on another mount unit
#   x-systemd.requires-mounts-for  - Require a mount point to exist first
#
# Filesystem Labels:
#   shani_boot - EFI System Partition (FAT32, 512 MiB minimum)
#   shani_root - Main Btrfs volume (contains all subvolumes)

##############################################################################


##############################################################################
# SECTION 1: UEFI BOOT PARTITION & RUNTIME TMPFS
##############################################################################

# EFI System Partition
# Contains systemd-boot loader, kernels, and initramfs images.
# noauto: not mounted by default; mounted explicitly when needed (e.g. updates).
LABEL=shani_boot              /boot/efi                 vfat    defaults,noatime,noauto   0 2

# Temporary runtime data — cleared on every reboot
tmpfs                         /tmp                      tmpfs   defaults,noatime   0 0
tmpfs                         /run                      tmpfs   defaults,noatime   0 0

##############################################################################
# SECTION 2: CORE PERSISTENT BTRFS SUBVOLUMES
##############################################################################

# /root — Root user home directory
# Persists across blue/green root switches same as @home.
# Create: btrfs subvolume create /@root
LABEL=shani_root              /root                     btrfs   defaults,noatime,subvol=@root,rw,compress=zstd,space_cache=v2,autodefrag   0 0

# /home — User files, dotfiles, and personal data
# Persists across blue/green root switches so users retain their data.
# Create: btrfs subvolume create /@home
LABEL=shani_root              /home                     btrfs   defaults,noatime,subvol=@home,rw,compress=zstd,space_cache=v2,autodefrag   0 0

# /data — Overlay backing storage and service state source tree
# Stores /etc overlay changes (in /data/overlay/etc) and all bind-mount
# service state directories (in /data/varlib and /data/varspool).
# Shared between blue and green so config and service state persist.
# Create: btrfs subvolume create /@data
# Then:   mkdir -p /data/overlay/etc/{upper,work}
LABEL=shani_root              /data                     btrfs   defaults,noatime,subvol=@data,rw,compress=zstd,space_cache=v2,autodefrag   0 0

##############################################################################
# SECTION 3: NIX PACKAGE STORE & PACKAGE CACHE
##############################################################################

# /nix — Nix package manager store
# Shared between blue and green roots so packages survive slot switches.
# CoW is intentionally kept to enable compression and deduplication via bees.
# nofail: boot continues if @nix does not yet exist.
# Create: btrfs subvolume create /@nix
LABEL=shani_root              /nix                      btrfs   nofail,noatime,subvol=@nix,rw,compress=zstd,space_cache=v2,autodefrag   0 0

# /var/cache — Package manager download and metadata cache
# Shared between roots to avoid re-downloading packages after slot switches.
# Create: btrfs subvolume create /@cache
LABEL=shani_root              /var/cache                btrfs   defaults,noatime,subvol=@cache,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

##############################################################################
# SECTION 4: SYSTEM LOGGING
##############################################################################

# /var/log — System and application logs
# Persistent across reboots and blue/green switches for troubleshooting.
# Create: btrfs subvolume create /@log
LABEL=shani_root              /var/log                  btrfs   defaults,noatime,subvol=@log,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

##############################################################################
# SECTION 5: OVERLAY FILESYSTEMS (WRITABLE /etc)
##############################################################################

# /etc — OverlayFS making the read-only root's /etc writable
# lowerdir: read-only /etc from the active root slot (@blue or @green)
# upperdir: writable layer in /data storing all modifications
# workdir:  required by OverlayFS for atomic rename operations
# Changes persist across blue/green switches via @data.
# Requires: mkdir -p /data/overlay/etc/{upper,work}
overlay   /etc   overlay   rw,lowerdir=/etc,upperdir=/data/overlay/etc/upper,workdir=/data/overlay/etc/work,index=off,metacopy=off,x-systemd.requires-mounts-for=/data   0 0

# /var overlay — Optional OverlayFS for /var (disabled by default)
# Enable only when NOT using the systemd.volatile=state kernel parameter.
# Requires: mkdir -p /data/overlay/var/{upper,work}
#overlay   /var   overlay   rw,lowerdir=/var,upperdir=/data/overlay/var/upper,workdir=/data/overlay/var/work,index=off,metacopy=off,x-systemd.requires-mounts-for=/data   0 0

##############################################################################
# SECTION 6: CONTAINER & VIRTUALIZATION PLATFORMS
##############################################################################

# /var/lib/flatpak — Flatpak runtimes and applications
# Keeps Flatpak apps available in both blue and green roots.
# Create: btrfs subvolume create /@flatpak
LABEL=shani_root              /var/lib/flatpak          btrfs   nofail,defaults,noatime,subvol=@flatpak,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/waydroid — Android system images and userdata
# Keeps Waydroid installed and persistent across blue/green root switches.
# Create: btrfs subvolume create /@waydroid
LABEL=shani_root              /var/lib/waydroid         btrfs   nofail,defaults,noatime,subvol=@waydroid,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/containers — Podman/Docker container images and volumes
# Keeps containers available in both blue and green roots.
# Create: btrfs subvolume create /@containers
LABEL=shani_root              /var/lib/containers       btrfs   nofail,defaults,noatime,subvol=@containers,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/machines — systemd-nspawn system containers
# Keeps system containers available in both blue and green roots.
# Create: btrfs subvolume create /@machines
LABEL=shani_root              /var/lib/machines         btrfs   nofail,defaults,noatime,subvol=@machines,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/lxc — LXC system and application containers
# Keeps LXC containers available in both blue and green roots.
# Create: btrfs subvolume create /@lxc
LABEL=shani_root              /var/lib/lxc              btrfs   nofail,defaults,noatime,subvol=@lxc,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/lxd — LXD container and VM storage
# Keeps LXD containers and VMs available in both blue and green roots.
# Create: btrfs subvolume create /@lxd
LABEL=shani_root              /var/lib/lxd              btrfs   nofail,defaults,noatime,subvol=@lxd,rw,compress=zstd,space_cache=v2,autodefrag,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/libvirt — libvirt daemon VM disk images and network state
# nodatacow for better VM disk I/O performance; nospace_cache required.
# Create: btrfs subvolume create /@libvirt
LABEL=shani_root              /var/lib/libvirt          btrfs   nofail,defaults,noatime,subvol=@libvirt,rw,nodatacow,nospace_cache,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

# /var/lib/qemu — bare QEMU VM disk images (without libvirt)
# nodatacow for better VM disk I/O performance; nospace_cache required.
# Create: btrfs subvolume create /@qemu
LABEL=shani_root              /var/lib/qemu             btrfs   nofail,defaults,noatime,subvol=@qemu,rw,nodatacow,nospace_cache,x-systemd.after=var.mount,x-systemd.requires=var.mount   0 0

##############################################################################
# SECTION 7: SWAP
##############################################################################

# /swap — Btrfs subvolume container for the swapfile
# nodatacow required for swap correctness; nospace_cache required with nodatacow.
# Create: btrfs subvolume create /@swap
LABEL=shani_root              /swap                     btrfs   nofail,noatime,subvol=@swap,rw,nodatacow,nospace_cache   0 0

# Swapfile — actual swap space inside the @swap subvolume
# Create: btrfs filesystem mkswapfile --size 8G /swap/swapfile
#         chmod 600 /swap/swapfile
/swap/swapfile                none                      swap    nofail,sw   0 0

##############################################################################
# SECTION 8: SYSTEM CORE STATE
##############################################################################

# /var/lib/dbus — D-Bus machine ID and system bus state
# Ensures a consistent machine-id across blue/green root switches.
# Requires: mkdir -p /data/varlib/dbus
/data/varlib/dbus             /var/lib/dbus             none    bind,nofail,x-systemd.after=var.mount,x-systemd.requires-mounts-for=/data   0 0

# /var/lib/systemd — systemd manager state, timers, and random seed
# Preserves unit states, timer schedules, and the persistent random seed.
# Requires: mkdir -p /data/varlib/systemd
/data/varlib/systemd          /var/lib/systemd          none    bind,nofail,x-systemd.after=var.mount,x-systemd.requires-mounts-for=/data   0 0

##############################################################################
# SECTION 9: FONT RENDERING
##############################################################################

# /var/lib/fontconfig — Font configuration and rendering cache
# Preserves font settings and cache across blue/green root switches.
# Requires: mkdir -p /data/varlib/fontconfig
/data/varlib/fontconfig       /var/lib/fontconfig       none    bind,nofail,x-systemd.after=var.mount,x-systemd.requires-mounts-for=/data   0 0

##############################################################################
