##############################################################################

# /var/lib/NetworkManager — Connection profiles, Wi-Fi passwords, VPN configs
# Keeps all network settings intact across blue/green root switches.
# Requires: mkdir -p /data/varlib/NetworkManager
/data/varlib/NetworkManager   /var/lib/NetworkManager   none    bind,nofail,x-systemd.after=var.mount,x-systemd.requires-mounts-for=/data   0 0

# /var/lib/bluetooth — Paired device database and keys
# Keeps Bluetooth pairings across blue/green root switches.
# Requires: mkdir -p /data/varlib/bluetooth
/data/varlib/bluetooth        /var/lib/bluetooth        none    bind,nofail,x-systemd.after=var.mount,x-systemd.requires-mounts-for=/data   0 0

# /var/lib/firewalld — Firewall rules and zone configuration
